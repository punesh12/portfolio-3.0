{
  "fontFamily": {
    "sans": "var(--font-sans), ui-sans-serif, system-ui, sans-serif",
    "mono": "var(--font-mono), ui-monospace, monospace"
  },
  "fontSize": {
    "xs": "12px",
    "sm": "14px",
    "base": "16px",
    "lg": "18px",
    "xl": "20px",
    "2xl": "24px",
    "3xl": "30px",
    "4xl": "36px",
    "5xl": "48px",
    "6xl": "60px",
    "7xl": "72px"
  },
  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "lineHeight": {
    "tight": 1.15,
    "snug": 1.3,
    "normal": 1.5,
    "relaxed": 1.65
  },
  "letterSpacing": {
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.02em"
  }
}
